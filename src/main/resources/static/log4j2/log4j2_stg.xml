<?xml version="1.0" encoding="UTF-8"?>
<Configuration >
    <!-- 해당 설정파일에서 사용하는 프로퍼티-->
    <Properties>
        <Property name="layoutPattern">%style{%d{yyyy/MM/dd HH:mm:ss,SSS}}{cyan} %highlight{[%-5p]}{FATAL=bg_red, ERROR=red, INFO=green, DEBUG=blue} [%C] %style{[%t]}{yellow} %m%n </Property>
        <Property name="path">/STG_SERVER/logs</Property>
    </Properties>
    <!-- LogEvent를 전달해주는 Appender-->
    <Appenders>
        <Console name="Console" target="SYSTEM_OUT">
            <PatternLayout pattern="${layoutPattern}"/>
        </Console>
        <RollingFile name="rootFile" fileName="${path}/root.log" filePattern="${path}/root_%d{yyyy-MM-dd}_%i.log.gz">
            <PatternLayout pattern="${layoutPattern}"/>
            <Policies>
                <SizeBasedTriggeringPolicy size="200KB"/>
                <TimeBasedTriggeringPolicy interval="1"/>
            </Policies>
            <DefaultRolloverStrategy max="10" fileIndex="min"/>
        </RollingFile>
        <RollingFile name="AuthFile" fileName="${path}/Auth.log" filePattern="${path}/Auth_%d{yyyy-MM-dd}_%i.log.gz">
            <PatternLayout pattern="${layoutPattern}"/>
            <Policies>
                <SizeBasedTriggeringPolicy size="200KB"/>
                <TimeBasedTriggeringPolicy interval="1"/>
            </Policies>
            <DefaultRolloverStrategy max="10" fileIndex="min"/>
        </RollingFile>
        <RollingFile name="TestFile" fileName="${path}/Test.log" filePattern="${path}/Test_%d{yyyy-MM-dd}_%i.log.gz">
            <PatternLayout pattern="${layoutPattern}"/>
            <Policies>
                <SizeBasedTriggeringPolicy size="200KB"/>
                <TimeBasedTriggeringPolicy interval="1"/>
            </Policies>
            <DefaultRolloverStrategy max="10" fileIndex="min"/>
        </RollingFile>
        <RollingFile name="IndexFile" fileName="${path}/Index.log" filePattern="${path}/Index_%d{yyyy-MM-dd}_%i.log.gz">
            <PatternLayout pattern="${layoutPattern}"/>
            <Policies>
                <SizeBasedTriggeringPolicy size="200KB"/>
                <TimeBasedTriggeringPolicy interval="1"/>
            </Policies>
            <DefaultRolloverStrategy max="10" fileIndex="min"/>
        </RollingFile>
    </Appenders>
    <!-- 실제 Logger-->
    <Loggers>
        <Root level="WARN" additivity="false">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="rootFile"/>
        </Root>
        <Logger name="me.synology.freash97.iptablecommandcode.Auth" level="WARN" additivity="false">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="AuthFile"/>
        </Logger>
        <Logger name="me.synology.freash97.iptablecommandcode.test" level="WARN" additivity="false">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="TestFile"/>
        </Logger>
        <Logger name="me.synology.freash97.iptablecommandcode.Index" level="WARN" additivity="false">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="IndexFile"/>
        </Logger>
    </Loggers>
</Configuration>